# Groq API (OpenAI-compatible) — Free tier
# Get your free key at https://console.groq.com
XAI_API_KEY=your_groq_api_key_here
XAI_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1024

# Data Paths
DATA_PATH=data/zomato.csv
DB_PATH=data/restaurants.db
VECTOR_DB_PATH=data/chroma_store

# Optimizations
CACHE_ENABLED=true
CACHE_TTL=3600
SESSION_ENABLED=true
SESSION_TTL=1800

# Logging
LOG_LEVEL=INFO
LOG_PATH=logs/queries.jsonl
